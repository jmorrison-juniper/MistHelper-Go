# Normalize line endings across platforms
* text=auto

# Force LF for source files
*.go text eol=lf
*.mod text eol=lf
*.sum text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.sh text eol=lf

# Force CRLF for Windows-specific files
*.ps1 text eol=crlf

# Binary files
*.exe binary
*.db binary
*.sqlite binary
