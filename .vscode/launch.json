{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run MistHelper-Go",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/misthelper",
      "envFile": "${workspaceFolder}/.env",
      "args": []
    },
    {
      "name": "Run MistHelper-Go (--version)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/misthelper",
      "args": ["-version"]
    },
    {
      "name": "Debug Tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/cmd/misthelper",
      "env": {
        "MIST_API_TOKEN": "test",
        "MIST_ORG_ID": "test"
      }
    }
  ]
}
