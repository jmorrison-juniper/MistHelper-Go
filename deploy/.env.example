# MistHelper-Go Environment Configuration (Deploy)
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to version control.

# ============================================================
# Required Variables
# ============================================================

# Juniper Mist API authentication token
# Obtain from Mist Dashboard > Organization > Settings > API Token
MIST_API_TOKEN=your_api_token_here

# Mist organization UUID
# Found in Mist Dashboard URL: https://manage.mist.com/admin/?org_id=<THIS_VALUE>
MIST_ORG_ID=your_org_id_here

# ============================================================
# Optional Variables
# ============================================================

# Mist API host (default: api.mist.com)
# MIST_API_HOST=api.mist.com

# Output backend: csv | sqlite | arangodb (default: csv)
# MIST_OUTPUT_BACKEND=csv

# SQLite database path (default: data/mist_data.db)
# MIST_SQLITE_PATH=data/mist_data.db

# API page size for paginated requests (default: 1000)
# MIST_PAGE_LIMIT=1000

# Maximum concurrent connections in fast mode (default: 8)
# FAST_MODE_MAX_CONCURRENT_CONNECTIONS=8

# Logging level: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# ============================================================
# Polyglot Database Backends (Optional)
# ============================================================

# ArangoDB connection (document storage for config entities)
# ARANGO_URL=http://arangodb:8529
# ARANGO_DB=misthelper
# ARANGO_USER=root
# ARANGO_PASSWORD=misthelper

# Redis Stack connection (time-series metrics + JSON event cache)
# REDIS_URL=redis://redis-stack:6379
# REDIS_PASSWORD=misthelper

# ============================================================
# SSH & Web UI
# ============================================================

# SSH server port (default: 2200)
# SSH_PORT=2200

# SSH credentials (change in production)
# SSH_USER=misthelper
# SSH_PASSWORD=misthelper123!

# Web portal port (default: 8055)
# WEB_PORT=8055
