# Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# Mist API token (required)
MIST_API_TOKEN=

# Your Mist org ID (required)
MIST_ORG_ID=

# Mist API host (optional, defaults to api.mist.com)
# MIST_API_HOST=api.mist.com

# Output backend: csv | sqlite | arangodb (default: csv)
MIST_OUTPUT_BACKEND=csv

# SQLite database path (used when MIST_OUTPUT_BACKEND=sqlite)
MIST_SQLITE_PATH=data/mist_data.db

# ArangoDB connection (used when MIST_OUTPUT_BACKEND=arangodb)
# ARANGO_URL=http://localhost:8529
# ARANGO_DB=misthelper
# ARANGO_USER=root
# ARANGO_PASSWORD=

# Redis connection (used with arangodb backend)
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# SSH server config
SSH_PORT=2200
SSH_USER=misthelper
# SSH_PASSWORD=  (set a strong password in production)

# Web UI config
WEB_PORT=8055

# Logging level: debug | info | warn | error (default: info)
LOG_LEVEL=info
